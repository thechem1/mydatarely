{
  "version": 2,
  "name": "edge-request-processor",
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "/api/handler" },
    { "source": "/health", "destination": "/api/status" },
    { "source": "/check/(.*)", "destination": "/api/validator" }
  ],
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "runtime": "edge",
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
